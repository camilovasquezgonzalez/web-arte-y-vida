      mediaType: 'CAROUSEL_ALBUM',
      caption:
        '🎭✨ Taller de Teatro para adultos | FormArte 2026\n\nAbrimos este espacio de expresión, encuentro y creación junto a Natalia Valenzuela.\n\n📍 Lugar: Casa Taller Arte y Vida, ubicada en Pedro León Gallo 547\n🕖 Horario: Miércoles 19:00 hrs.\n👥 Público: Mayores de 18 años\n\nInscríbete a través del link en nuestra bio o busca el formulario en nuestras historias destacadas 💜',
      cover:
        'https://behold.pictures/6CJI9ZwlwXWfIMGd2pPh7MvdAxk2/4gCtfgh1AA9Oqq4SFGb5/18261836056293477/medium.jpg'
    }
  ]
};
const facebookFollowersCount: number | null = 3900;

const formatDate = (isoString: string) => {
  const date = new Date(isoString);
  if (Number.isNaN(date.valueOf())) return 'Instagram';
  return date.toLocaleDateString('es-CL', { day: '2-digit', month: 'short', year: 'numeric' });
};

const displayPosts: PostItem[] = feed.posts.slice(0, 6);
---

<section class="bg-brand-white/5 text-brand-white reveal-section" id="instagram">
  <div class="mx-auto grid max-w-[1280px] grid-cols-1 items-start gap-10 px-5 py-16 sm:px-10 sm:py-20 lg:grid-cols-12 lg:gap-16 lg:py-28 xl:max-w-[1440px]">
    <div class="lg:col-span-4 space-y-5">
      <p class="text-xs font-black uppercase tracking-[0.3em] text-brand-secondary">Instagram</p>
      <div class="flex items-start gap-4">
        <img src={feed.profilePictureUrl} alt={`Avatar de ${feed.username}`} loading="lazy" class="h-14 w-14 rounded-2xl border border-brand-white/15 shadow-[0_15px_40px_rgba(0,0,0,0.35)] object-cover" />
        <div class="space-y-1.5">
          <div class="flex items-center gap-2">
            <h3 class="text-2xl font-black leading-tight">@{feed.username}</h3>
            <span class="inline-flex items-center gap-1 rounded-full bg-brand-accent text-brand-bg text-[11px] font-black uppercase tracking-[0.2em] px-2.5 py-1 shadow-[0_10px_30px_rgba(254,209,0,0.35)]">Online</span>
          </div>
          <p class="text-brand-white/70 text-sm leading-relaxed whitespace-pre-line">{feed.biography}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-brand-white/10 bg-brand-bg/70 px-4 py-3">
          <div class="text-xl font-black">{feed.followersCount.toLocaleString('es-CL')}</div>
          <div class="text-[11px] uppercase tracking-[0.2em] text-brand-white/60">Seguidores</div>
        </div>
        <div class="rounded-2xl border border-brand-white/10 bg-brand-bg/70 px-4 py-3">
          <div class="text-xl font-black">{feed.followsCount.toLocaleString('es-CL')}</div>
          <div class="text-[11px] uppercase tracking-[0.2em] text-brand-white/60">Siguiendo</div>
        </div>
        <div class="rounded-2xl border border-brand-white/10 bg-brand-bg/70 px-4 py-3">
          <div class="text-xl font-black">{facebookFollowersCount !== null ? facebookFollowersCount.toLocaleString('es-CL') : '—'}</div>
          <div class="text-[11px] uppercase tracking-[0.2em] text-brand-white/60">Seguidores en Facebook</div>
        </div>
      </div>

      <div class="flex flex-col items-stretch gap-3 sm:flex-row sm:flex-wrap sm:items-center">
        <a
          href={`https://www.instagram.com/${feed.username}`}
          target="_blank"
          rel="noreferrer"
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-brand-accent px-5 py-2.5 text-xs font-black uppercase tracking-[0.2em] text-brand-bg shadow-[0_15px_50px_rgba(254,209,0,0.3)] transition-transform duration-300 hover:translate-y-[-1px]"
        >
          Ver perfil completo
          <span class="h-2.5 w-2.5 inline-block rotate-45 border-t border-r border-current"></span>
        </a>

        <a
          href={feed.website}
          target="_blank"
          rel="noreferrer"
          class="inline-flex min-h-12 items-center justify-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-brand-white/80 hover:text-brand-accent"
        >
          Visita nuestro Facebook
          <span class="h-2.5 w-2.5 inline-block rotate-45 border-t border-r border-current"></span>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:col-span-8 md:grid-cols-3">
      {displayPosts.map((post, index) => (
        <a
          href={post.permalink}
          target="_blank"
          rel="noreferrer"
          class="reveal-card group relative overflow-hidden rounded-3xl border border-brand-white/10 bg-brand-bg/70 shadow-[0_20px_70px_rgba(0,0,0,0.3)] transition-all duration-300 hover:border-brand-accent/60 hover:-translate-y-1"
          style={`animation-delay: ${index * 120}ms;`}
        >
          <div class="relative h-52 w-full">
            <img src={post.cover} alt={`Publicación de ${feed.username}`} loading="lazy" class="h-full w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent"></div>
            <div class="absolute top-3 left-3 inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-white backdrop-blur-sm border border-white/20">
              <span class="h-2 w-2 rounded-full bg-brand-accent"></span>
              {post.mediaType === 'CAROUSEL_ALBUM' ? 'Carrusel' : 'Post'}
            </div>
          </div>

          <div class="px-5 py-4 flex flex-col gap-3">
            <div class="flex items-center justify-between text-[11px] uppercase tracking-[0.18em] text-brand-white/60">
              <span>{formatDate(post.timestamp)}</span>
              <span class="inline-flex items-center gap-1 text-brand-accent font-semibold">
                Instagram
              </span>
            </div>
            <p class="text-sm leading-relaxed text-brand-white/80 line-clamp-3">{post.caption}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
