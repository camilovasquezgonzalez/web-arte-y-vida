---
const navSections = [
  { type: 'link', label: 'Inicio', href: '/' },
  {
    type: 'group',
    label: 'Nosotros',
    children: [
      { label: 'Nuestra historia', href: '/nuestra-historia' },
      { label: 'Nuestros socios', href: '/socios' },
      { label: 'Transparencia', href: '/transparencia' },
    ],
  },
  { type: 'link', label: 'Noticias', href: '/noticias' },
  { type: 'link', label: 'Proyectos', href: '/proyectos' },
  { type: 'link', label: 'Arte y Vida TV', href: '/arte-y-vida-tv' },
  { type: 'link', label: 'Contacto', href: '/contacto' },
];

const socialLinks = [
  {
    name: 'Facebook',
    href: 'http://facebook.com/@corparteyvida',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="h-5 w-5"><path d="M13.4 20.8v-7h2.3l.3-2.7h-2.6v-1.7c0-.8.2-1.3 1.4-1.3h1.3V5c-.2 0-1.1-.1-2.1-.1-2.1 0-3.6 1.3-3.6 3.7v2.1H8v2.7h2.4v7h3z"/></svg>`,
  },
  {
    name: 'Instagram',
    href: 'http://instagram.com/corparteyvida',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-5 w-5"><rect x="3" y="3" width="18" height="18" rx="5" ry="5" stroke-width="2"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg>`,
  },
  {
    name: 'YouTube',
    href: 'https://www.youtube.com/@corparteyvida',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="h-5 w-5"><path d="M21.6 7.2s-.2-1.4-.8-2c-.7-.7-1.5-.7-1.9-.7C16.4 4.2 12 4.2 12 4.2h-.1s-4.4 0-6.9.3c-.4 0-1.2 0-1.9.7-.6.6-.8 2-.8 2S2 8.8 2 10.4v1.2c0 1.6.2 3.2.2 3.2s.2 1.4.8 2c.7.7 1.7.7 2.2.7 1.6.2 6.8.3 6.8.3s4.4 0 6.9-.3c.4 0 1.2 0 1.9-.7.6-.6.8-2 .8-2s.2-1.6.2-3.2v-1.2c0-1.6-.2-3.2-.2-3.2ZM10 14.8V8.9l5.1 3-5.1 2.9Z"/></svg>`,
  },
];
---

<aside
  id="sidebar-shell"
  class="pointer-events-none fixed inset-x-4 top-4 z-50 isolate flex flex-col gap-6 md:inset-x-auto md:left-4 md:top-1/2 md:-translate-y-1/2"
>
  <div class="pointer-events-auto hidden flex-col gap-6 pl-1 md:flex">
    <div class="flex items-center gap-3 text-brand-white">
      <img src="/blanco-scaled.webp" alt="Corporaci&oacute;n Arte y Vida" class="h-14 w-auto drop-shadow-[0_10px_30px_rgba(0,0,0,0.35)]" />
      <div class="flex flex-col leading-tight">
        <span class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-white/80">Corporaci&oacute;n</span>
        <span class="text-xl font-black tracking-tight">Arte y Vida</span>
      </div>
    </div>

    <nav class="flex flex-col gap-4 leading-tight text-brand-white">
      {navSections.map((entry) =>
        entry.type === 'link' ? (
          <a
            href={entry.href}
            class="border-l border-brand-white/10 pl-2 text-base font-semibold transition-colors hover:border-brand-accent/70 hover:text-brand-accent"
          >
            {entry.label}
          </a>
        ) : (
          <div class="sidebar-group border-l border-brand-white/10 pl-2">
            <div class="sidebar-group-trigger flex min-h-7 items-center justify-between gap-3 text-base font-semibold text-brand-white transition-colors">
              <span>{entry.label}</span>
              <span class="sidebar-group-chevron inline-block h-2.5 w-2.5 rotate-45 border-b border-r border-brand-white/45 transition-all duration-300"></span>
            </div>
            <div class="sidebar-group-menu flex flex-col gap-2">
              {entry.children.map((child) => (
                <a href={child.href} class="text-sm text-brand-white/80 transition-colors hover:text-brand-white">
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ),
      )}
    </nav>
  </div>

  <button
    id="sidebar-toggle"
    type="button"
    class="pointer-events-auto relative z-[80] flex h-12 w-12 items-center justify-center self-start rounded-full border border-brand-white/15 bg-brand-bg/82 text-brand-white shadow-[0_18px_50px_rgba(0,0,0,0.45)] backdrop-blur-xl transition-all duration-300 hover:border-brand-accent/70 hover:shadow-[0_12px_38px_rgba(254,209,0,0.2)] md:hidden"
    aria-label="Abrir men&uacute; principal"
    aria-controls="sidebar-panel"
    aria-expanded="false"
    aria-haspopup="dialog"
  >
    <span class="sr-only">Abrir men&uacute; principal</span>
    <span class="line line-1"></span>
    <span class="line line-2"></span>
    <span class="line line-3"></span>
  </button>

  <div
    id="sidebar-overlay"
    hidden
    aria-hidden="true"
    class="pointer-events-auto fixed inset-0 z-[60] bg-black/72 md:hidden"
  ></div>

  <div
    id="sidebar-panel"
    hidden
    tabindex="-1"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="sidebar-panel-title"
    class="pointer-events-auto fixed inset-x-4 bottom-4 top-20 z-[70] md:hidden"
  >
    <div class="mobile-menu-card overflow-hidden rounded-[1.75rem] border border-brand-white/10 bg-[linear-gradient(180deg,rgba(8,8,8,0.98),rgba(8,8,8,0.95))] shadow-[0_25px_90px_rgba(0,0,0,0.55)]">
      <div class="absolute inset-0 opacity-45 bg-[radial-gradient(circle_at_85%_14%,rgba(49,204,231,0.85)_0%,transparent_30%),radial-gradient(circle_at_10%_78%,rgba(197,48,149,0.7)_0%,transparent_28%)]"></div>

      <div class="mobile-menu-content relative">
        <div class="flex items-start justify-between gap-4 border-b border-brand-white/10 px-5 pb-4 pt-5">
          <div>
            <p id="sidebar-panel-title" class="text-[11px] font-semibold uppercase tracking-[0.28em] text-brand-white/70">
              Navegaci&oacute;n
            </p>
            <p class="mt-1 text-sm font-semibold text-brand-white">Arte y Vida</p>
          </div>

          <button
            id="sidebar-close"
            type="button"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-brand-white/10 bg-brand-white/5 text-brand-white/85 transition-colors hover:border-brand-accent/60 hover:text-brand-accent"
            aria-label="Cerrar men&uacute; principal"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="2">
              <path d="M6 6l12 12M18 6 6 18" stroke-linecap="round" />
            </svg>
          </button>
        </div>

        <nav class="min-h-0 flex-1 space-y-3 overflow-y-auto px-5 py-5" aria-label="Men&uacute; principal">
          {navSections.map((entry) =>
            entry.type === 'link' ? (
              <a
                href={entry.href}
                class="mobile-menu-link group block rounded-[1.35rem] border border-brand-white/5 bg-brand-white/6 px-4 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-brand-white/92 transition-all duration-300 hover:border-brand-accent/50 hover:bg-brand-white/10 hover:text-brand-white"
              >
                <span class="flex items-center justify-between gap-4">
                  <span class="min-w-0 whitespace-normal text-left leading-relaxed">{entry.label}</span>
                  <span class="h-px w-8 shrink-0 bg-brand-white/25 transition-all duration-300 group-hover:w-14 group-hover:bg-brand-accent"></span>
                </span>
              </a>
            ) : (
              <div class="rounded-[1.35rem] border border-brand-white/5 bg-brand-white/6 px-4 py-4">
                <div class="mb-3 text-[11px] font-black uppercase tracking-[0.24em] text-brand-accent">{entry.label}</div>
                <div class="space-y-2">
                  {entry.children.map((child) => (
                    <a
                      href={child.href}
                      class="mobile-menu-link group flex items-center justify-between gap-3 rounded-[1.15rem] border border-brand-white/5 bg-brand-bg/55 px-4 py-4 text-sm font-semibold tracking-[0.08em] text-brand-white/88 transition-all duration-300 hover:border-brand-accent/50 hover:text-brand-white"
                    >
                      <span class="min-w-0 whitespace-normal text-left leading-relaxed">{child.label}</span>
                      <span class="h-px w-6 shrink-0 bg-brand-white/25 transition-all duration-300 group-hover:w-10 group-hover:bg-brand-accent"></span>
                    </a>
                  ))}
                </div>
              </div>
            ),
          )}
        </nav>

        <div class="border-t border-brand-white/10 px-5 py-5">
          <div class="mb-3 text-[11px] font-semibold uppercase tracking-[0.22em] text-brand-white/70">S&iacute;guenos</div>
          <div class="flex flex-wrap items-center gap-3 text-brand-white/80">
            {socialLinks.map((item) => (
              <a
                href={item.href}
                aria-label={item.name}
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-brand-white/10 bg-brand-white/5 transition-colors hover:border-brand-accent/50 hover:text-brand-accent"
                target="_blank"
                rel="noreferrer"
              >
                <span class="inline-flex h-5 w-5 items-center justify-center" set:html={item.icon}></span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</aside>

<style>
  #sidebar-toggle .line {
    position: absolute;
    width: 20px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease,
      width 0.3s ease;
  }

  #sidebar-toggle .line-1 {
    transform: translateY(-6px);
  }

  #sidebar-toggle .line-2 {
    width: 16px;
    transform: translateY(0);
  }

  #sidebar-toggle .line-3 {
    transform: translateY(6px);
  }

  #sidebar-toggle[data-open='true'] .line-1 {
    width: 20px;
    transform: translateY(0) rotate(45deg);
  }

  #sidebar-toggle[data-open='true'] .line-2 {
    opacity: 0;
    transform: translateX(-8px);
  }

  #sidebar-toggle[data-open='true'] .line-3 {
    width: 20px;
    transform: translateY(0) rotate(-45deg);
  }

  .mobile-menu-card {
    position: relative;
    display: flex;
    height: 100%;
    flex-direction: column;
  }

  .mobile-menu-content {
    display: flex;
    min-height: 0;
    flex: 1 1 auto;
    flex-direction: column;
  }

  #sidebar-panel {
    display: none;
  }

  #sidebar-panel.is-open {
    display: block;
  }

  #sidebar-overlay {
    display: none;
  }

  #sidebar-overlay.is-open {
    display: block;
  }

  .sidebar-group {
    position: relative;
  }

  .sidebar-group-menu {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    padding-top: 0;
    transform: translateY(-4px);
    transition:
      max-height 0.3s ease,
      opacity 0.25s ease,
      transform 0.25s ease,
      padding-top 0.25s ease;
  }

  .sidebar-group:hover,
  .sidebar-group:focus-within {
    border-color: rgba(254, 209, 0, 0.7);
  }

  .sidebar-group:hover .sidebar-group-trigger,
  .sidebar-group:focus-within .sidebar-group-trigger {
    color: #fed100;
  }

  .sidebar-group:hover .sidebar-group-chevron,
  .sidebar-group:focus-within .sidebar-group-chevron {
    transform: rotate(45deg) translate(2px, 2px);
    border-color: #fed100;
  }

  .sidebar-group:hover .sidebar-group-menu,
  .sidebar-group:focus-within .sidebar-group-menu {
    max-height: 180px;
    opacity: 1;
    padding-top: 10px;
    transform: translateY(0);
  }

  @media (max-width: 767px) {
    #sidebar-shell {
      top: max(1rem, env(safe-area-inset-top));
    }

    #sidebar-panel {
      top: calc(max(1rem, env(safe-area-inset-top)) + 3.75rem);
      bottom: calc(max(1rem, env(safe-area-inset-bottom)) + 0.5rem);
    }
  }
</style>

<script>
  const initSidebarNav = () => {
    window.__sidebarNavCleanup?.();

    const toggle = document.getElementById('sidebar-toggle');
    const panel = document.getElementById('sidebar-panel');
    const overlay = document.getElementById('sidebar-overlay');
    const closeButton = document.getElementById('sidebar-close');

    if (
      !(toggle instanceof HTMLButtonElement) ||
      !(panel instanceof HTMLElement) ||
      !(overlay instanceof HTMLElement)
    ) {
      return;
    }

    const focusableSelector = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';
    const getIsOpen = () => toggle.getAttribute('data-open') === 'true';

    const lockBodyScroll = () => {
      document.documentElement.style.overflow = 'hidden';
      document.body.classList.add('mobile-nav-open');
      document.body.style.overflow = 'hidden';
    };

    const unlockBodyScroll = () => {
      document.documentElement.style.overflow = '';
      document.body.classList.remove('mobile-nav-open');
      document.body.style.overflow = '';
    };

    const setOpen = (value, options = {}) => {
      const isOpen = Boolean(value);
      const returnFocus = options.returnFocus ?? !isOpen;

      toggle.setAttribute('data-open', String(isOpen));
      toggle.setAttribute('aria-expanded', String(isOpen));
      toggle.setAttribute('aria-label', isOpen ? 'Cerrar menu principal' : 'Abrir menu principal');
      panel.setAttribute('aria-hidden', String(!isOpen));
      overlay.setAttribute('aria-hidden', String(!isOpen));

      panel.hidden = !isOpen;
      overlay.hidden = !isOpen;
      panel.style.display = isOpen ? 'block' : 'none';
      overlay.style.display = isOpen ? 'block' : 'none';
      panel.classList.toggle('is-open', isOpen);
      overlay.classList.toggle('is-open', isOpen);

      if (isOpen) {
        lockBodyScroll();
        requestAnimationFrame(() => {
          const firstFocusable = panel.querySelector(focusableSelector);
          if (firstFocusable instanceof HTMLElement) firstFocusable.focus();
          else panel.focus();
        });
        return;
      }

      unlockBodyScroll();
      if (returnFocus) toggle.focus();
    };

    const handleToggle = () => {
      setOpen(!getIsOpen(), { returnFocus: false });
    };

    const handleClose = () => {
      setOpen(false);
    };

    const handlePanelClick = (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest('a[href]')) {
        setOpen(false, { returnFocus: false });
      }
    };

    const handleKeydown = (event) => {
      if (!getIsOpen()) return;

      if (event.key === 'Escape') {
        event.preventDefault();
        setOpen(false);
        return;
      }

      if (event.key !== 'Tab') return;

      const focusableElements = Array.from(panel.querySelectorAll(focusableSelector)).filter(
        (element) => element instanceof HTMLElement && !element.hasAttribute('disabled'),
      );

      if (!focusableElements.length) {
        event.preventDefault();
        panel.focus();
        return;
      }

      const firstElement = focusableElements[0];
      const lastElement = focusableElements[focusableElements.length - 1];

      if (event.shiftKey && document.activeElement === firstElement) {
        event.preventDefault();
        lastElement.focus();
      } else if (!event.shiftKey && document.activeElement === lastElement) {
        event.preventDefault();
        firstElement.focus();
      }
    };

    const handleResize = () => {
      if (window.innerWidth >= 768) {
        setOpen(false, { returnFocus: false });
      }
    };

    toggle.addEventListener('click', handleToggle);
    closeButton?.addEventListener('click', handleClose);
    overlay.addEventListener('click', handleClose);
    document.addEventListener('keydown', handleKeydown);
    panel.addEventListener('click', handlePanelClick);
    window.addEventListener('resize', handleResize);

    setOpen(false, { returnFocus: false });

    window.__sidebarNavCleanup = () => {
      toggle.removeEventListener('click', handleToggle);
      closeButton?.removeEventListener('click', handleClose);
      overlay.removeEventListener('click', handleClose);
      document.removeEventListener('keydown', handleKeydown);
      panel.removeEventListener('click', handlePanelClick);
      window.removeEventListener('resize', handleResize);
      panel.hidden = true;
      overlay.hidden = true;
      panel.style.display = 'none';
      overlay.style.display = 'none';
      panel.classList.remove('is-open');
      overlay.classList.remove('is-open');
      unlockBodyScroll();
    };
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebarNav, { once: true });
  } else {
    initSidebarNav();
  }

  document.addEventListener('astro:page-load', initSidebarNav);
</script>
