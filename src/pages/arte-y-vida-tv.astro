---
import Layout from '../layouts/Layout.astro';
import SidebarNav from '../components/SidebarNav.astro';
import { formatYouTubeDate, getYouTubeLibrary, getYouTubeVideos } from '../lib/youtube';

const { videos, loadError } = await getYouTubeVideos(6);
const { playlists, loadError: libraryError } = await getYouTubeLibrary(50);

const floresYSombras = {
  id: '40efH5D1BCM',
  title: 'Flores y Sombras: Una historia sobre el Cementerio de Coelemu',
  thumbnail: 'https://i.ytimg.com/vi/40efH5D1BCM/hqdefault.jpg',
  publishedAt: '2024-12-28T23:00:04Z',
  description:
    'Cortometraje documental que recorre la memoria, los relatos y los simbolos del Cementerio de Coelemu desde una mirada sensible y territorial.',
};

const featuredVideo = floresYSombras;
const featuredUrl = `https://www.youtube.com/watch?v=${featuredVideo.id}`;
const featuredEmbed = `https://www.youtube-nocookie.com/embed/${featuredVideo.id}`;
const spotlightVideos = videos.filter((video) => video.id !== featuredVideo.id).slice(0, 3);
const libraryLead = playlists[0];
const libraryRest = playlists.slice(1);
---

<Layout title="Arte y Vida TV">
  <SidebarNav />

  <section class="relative overflow-hidden bg-brand-bg pb-14 pt-20 text-brand-white lg:pb-18 lg:pt-24">
    <div class="absolute inset-0 opacity-80 bg-[radial-gradient(circle_at_top_right,rgba(197,48,149,0.24),transparent_28%),radial-gradient(circle_at_left,rgba(49,204,231,0.2),transparent_26%),linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0))]"></div>
    <div class="relative mx-auto grid max-w-[1280px] grid-cols-1 items-start gap-10 px-6 sm:px-10 lg:grid-cols-12 lg:gap-14 xl:max-w-[1440px]">
      <div class="space-y-5 lg:col-span-4">
        <p class="text-xs font-black uppercase tracking-[0.3em] text-brand-secondary">Arte y Vida TV</p>
        <h1 class="text-3xl font-black leading-tight sm:text-4xl md:text-5xl">Una pantalla para nuestra memoria audiovisual.</h1>
        <p class="max-w-xl text-base leading-relaxed text-brand-white/70 md:text-lg">
          Documentales, registros territoriales, coberturas y estrenos que muestran la vida cultural que compartimos con las comunidades.
        </p>

        <div class="flex flex-wrap items-center gap-3 text-[11px] uppercase tracking-[0.22em] text-brand-white/65">
          <span class="rounded-full border border-brand-white/10 bg-brand-white/5 px-3 py-2">Canal oficial</span>
          <span class="rounded-full border border-brand-white/10 bg-brand-white/5 px-3 py-2">YouTube</span>
          <span class="rounded-full border border-brand-white/10 bg-brand-white/5 px-3 py-2">Series y especiales</span>
        </div>

        {(loadError || libraryError) && (
          <div class="rounded-3xl border border-brand-white/10 bg-brand-white/5 px-5 py-4 text-sm leading-relaxed text-brand-white/80">
            {loadError || libraryError}
          </div>
        )}

        <div class="flex flex-col items-stretch gap-3 sm:flex-row sm:flex-wrap">
          <a
            href="https://www.youtube.com/@corparteyvida"
            target="_blank"
            rel="noreferrer"
            class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-brand-accent px-5 py-3 text-xs font-black uppercase tracking-[0.2em] text-brand-bg shadow-[0_12px_40px_rgba(254,209,0,0.28)] transition-transform duration-300 hover:-translate-y-[2px]"
          >
            Ir al canal
          </a>
          <a
            href="#biblioteca-proyectos"
            class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-brand-white/15 px-5 py-3 text-xs font-black uppercase tracking-[0.2em] text-brand-white transition-colors hover:border-brand-accent/70 hover:text-brand-accent"
          >
            Explorar catalogo
          </a>
        </div>
      </div>

      <div class="lg:col-span-8">
        <div class="overflow-hidden rounded-[32px] border border-brand-white/10 bg-brand-white/5 shadow-[0_25px_100px_rgba(0,0,0,0.45)] backdrop-blur-xl">
          <div class="flex items-center justify-between border-b border-brand-white/10 px-5 py-3 text-[11px] uppercase tracking-[0.24em] text-brand-white/55">
            <span>Senal destacada</span>
            <span>Arte y Vida TV</span>
          </div>

          <div class="aspect-video bg-black">
            <iframe
              src={featuredEmbed}
              title={featuredVideo.title}
              class="h-full w-full border-0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
              referrerpolicy="strict-origin-when-cross-origin"
            ></iframe>
          </div>

          <div class="space-y-3 px-6 py-6 lg:px-8">
            <div class="flex flex-wrap items-center gap-3 text-[11px] uppercase tracking-[0.22em] text-brand-white/60">
              <span>{formatYouTubeDate(featuredVideo.publishedAt)}</span>
              <span class="inline-flex items-center gap-2 text-brand-accent">
                <span class="h-1.5 w-1.5 rounded-full bg-brand-accent"></span>
                Estreno destacado
              </span>
            </div>
            <h2 class="text-2xl font-black leading-tight md:text-3xl">{featuredVideo.title}</h2>
            <p class="max-w-3xl text-sm leading-relaxed text-brand-white/72">{featuredVideo.description}</p>
            <a
              href={featuredUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-[0.18em] text-brand-accent hover:text-brand-white"
            >
              Ver en YouTube
              <span class="inline-block h-2.5 w-2.5 rotate-45 border-r border-t border-current"></span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-white/5 py-16 text-brand-white lg:py-20">
    <div class="mx-auto max-w-[1280px] space-y-8 px-6 sm:px-10 xl:max-w-[1440px]">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.3em] text-brand-accent">En vitrina</p>
          <h2 class="text-3xl font-black leading-tight">Capsulas, registros y estrenos recientes.</h2>
        </div>
        <p class="max-w-xl text-sm text-brand-white/65">
          Explora una seleccion pensada como parrilla audiovisual: piezas para ver, compartir y volver a visitar.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {spotlightVideos.map((video, index) => (
          <a
            href={video.id.startsWith('http') ? video.id : `https://www.youtube.com/watch?v=${video.id}`}
            target="_blank"
            rel="noreferrer"
            class="group overflow-hidden rounded-[28px] border border-brand-white/10 bg-brand-bg/80 shadow-[0_20px_70px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-1 hover:border-brand-accent/60"
            style={`animation-delay: ${index * 120}ms;`}
          >
            <div class="relative h-52">
              <img src={video.thumbnail} alt={video.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/15 to-transparent"></div>
              <div class="absolute left-4 top-4 inline-flex items-center gap-2 rounded-full border border-white/15 bg-black/30 px-3 py-1 text-[11px] font-black uppercase tracking-[0.18em] text-brand-white backdrop-blur">
                Senal {index + 1}
              </div>
            </div>
            <div class="space-y-3 px-5 py-5">
              <div class="text-[11px] uppercase tracking-[0.22em] text-brand-white/55">{formatYouTubeDate(video.publishedAt)}</div>
              <h3 class="text-xl font-bold leading-tight group-hover:text-brand-accent">{video.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="biblioteca-proyectos" class="bg-brand-bg py-16 text-brand-white lg:py-20">
    <div class="mx-auto max-w-[1280px] space-y-8 px-6 sm:px-10 xl:max-w-[1440px]">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.3em] text-brand-secondary">Colecciones</p>
          <h2 class="text-3xl font-black leading-tight">Series, proyectos y especiales para seguir viendo.</h2>
        </div>
        <p class="max-w-2xl text-sm text-brand-white/65">
          Elige una coleccion y sumergite en documentales, registros, coberturas y momentos clave de nuestro trabajo cultural.
        </p>
      </div>

      <div class="text-[11px] uppercase tracking-[0.22em] text-brand-white/50">
        {playlists.length} colecciones visibles en Arte y Vida TV
      </div>

      {libraryLead && (
        <article class="overflow-hidden rounded-[36px] border border-brand-white/10 bg-brand-white/5 shadow-[0_20px_70px_rgba(0,0,0,0.28)]">
          <div class="grid grid-cols-1 lg:grid-cols-12">
            <div class="relative min-h-[280px] lg:col-span-5">
              <img src={libraryLead.thumbnail || libraryLead.videos[0]?.thumbnail || '/DSC06842-scaled.webp'} alt={libraryLead.title} class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/35 to-transparent"></div>
              <div class="absolute bottom-6 left-6 right-6">
                <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-white/15 bg-black/30 px-3 py-1 text-[11px] font-black uppercase tracking-[0.18em] text-brand-white backdrop-blur">
                  Coleccion destacada
                </div>
                <h3 class="text-3xl font-black leading-tight">{libraryLead.title}</h3>
              </div>
            </div>

            <div class="flex flex-col gap-6 px-6 py-6 lg:col-span-7 lg:px-8 lg:py-8">
              <div class="space-y-3">
                <div class="flex flex-wrap items-center gap-3 text-[11px] uppercase tracking-[0.22em] text-brand-white/55">
                  <span>{libraryLead.videoCount || libraryLead.videos.length} videos</span>
                  <span class="inline-flex items-center gap-2 text-brand-accent">
                    <span class="h-1.5 w-1.5 rounded-full bg-brand-accent"></span>
                    Seleccion destacada
                  </span>
                </div>
                <p class="max-w-2xl text-sm leading-relaxed text-brand-white/72">
                  {libraryLead.description || 'Una seleccion audiovisual para recorrer la memoria, los hitos y los momentos principales de esta serie.'}
                </p>
                <a
                  href={libraryLead.playlistUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center gap-2 rounded-full border border-brand-accent/40 px-4 py-2 text-xs font-black uppercase tracking-[0.18em] text-brand-accent transition-colors duration-300 hover:bg-brand-accent hover:text-brand-bg"
                >
                  Ver serie completa
                  <span class="inline-block h-2.5 w-2.5 rotate-45 border-r border-t border-current"></span>
                </a>
              </div>

              <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                {libraryLead.videos.slice(0, 4).map((video) => (
                  <a
                    href={`https://www.youtube.com/watch?v=${video.id}`}
                    target="_blank"
                    rel="noreferrer"
                    class="group flex items-center gap-4 rounded-3xl border border-brand-white/10 bg-brand-bg/60 px-4 py-4 transition-all duration-300 hover:border-brand-accent/50"
                  >
                    <img src={video.thumbnail} alt={video.title} class="h-20 w-32 shrink-0 rounded-2xl object-cover" loading="lazy" />
                    <div class="min-w-0">
                      <div class="mb-2 text-[11px] uppercase tracking-[0.22em] text-brand-white/55">{formatYouTubeDate(video.publishedAt)}</div>
                      <h4 class="line-clamp-2 text-base font-bold leading-tight text-brand-white/85 group-hover:text-brand-accent">{video.title}</h4>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </article>
      )}

      {libraryRest.length > 0 && (
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {libraryRest.map((playlist, index) => (
            <article
              class="overflow-hidden rounded-[32px] border border-brand-white/10 bg-brand-white/5 shadow-[0_20px_70px_rgba(0,0,0,0.28)]"
              style={`animation-delay: ${index * 90}ms;`}
            >
              <div class="relative h-52">
                <img src={playlist.thumbnail || playlist.videos[0]?.thumbnail || '/DSC06842-scaled.webp'} alt={playlist.title} class="h-full w-full object-cover" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
                <div class="absolute bottom-5 left-5 right-5">
                  <div class="mb-2 flex items-center justify-between gap-3 text-[11px] uppercase tracking-[0.22em] text-brand-white/65">
                    <span>{playlist.videoCount || playlist.videos.length} videos</span>
                    <span>Serie</span>
                  </div>
                  <h3 class="text-2xl font-black leading-tight">{playlist.title}</h3>
                </div>
              </div>

              <div class="space-y-4 px-5 py-5">
                <p class="text-sm leading-relaxed text-brand-white/72">
                  {playlist.description || 'Una coleccion disponible para seguir viendo esta serie en Arte y Vida TV.'}
                </p>

                <div class="space-y-3">
                  {playlist.videos.slice(0, 3).map((video) => (
                    <a
                      href={`https://www.youtube.com/watch?v=${video.id}`}
                      target="_blank"
                      rel="noreferrer"
                      class="group flex items-center gap-3 rounded-2xl border border-brand-white/10 bg-brand-bg/60 px-3 py-3 transition-colors hover:border-brand-accent/50"
                    >
                      <img src={video.thumbnail} alt={video.title} class="h-16 w-24 shrink-0 rounded-xl object-cover" loading="lazy" />
                      <div class="min-w-0">
                        <div class="mb-1 text-[11px] uppercase tracking-[0.2em] text-brand-white/50">{formatYouTubeDate(video.publishedAt)}</div>
                        <h4 class="line-clamp-2 text-sm font-bold leading-tight text-brand-white/82 group-hover:text-brand-accent">{video.title}</h4>
                      </div>
                    </a>
                  ))}
                </div>

                <a
                  href={playlist.playlistUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-[0.18em] text-brand-accent hover:text-brand-white"
                >
                  Ver serie completa
                  <span class="inline-block h-2.5 w-2.5 rotate-45 border-r border-t border-current"></span>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
