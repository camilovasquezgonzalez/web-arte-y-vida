---
import SidebarNav from '../components/SidebarNav.astro';
import Layout from '../layouts/Layout.astro';

const previewPdfUrl = '/documentos/memoria-anual-2024-web.pdf';
const previewPdfSizeLabel = '2.1 MB';
const originalPdfUrl = '/documentos/memoria-anual-2024.pdf';
const originalPdfSizeLabel = '108.6 MB';
---

<Layout title="Memoria Anual 2024">
  <SidebarNav />

  <section class="bg-brand-bg pb-14 pt-20 text-brand-white lg:pb-16 lg:pt-24">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-10 xl:max-w-[1440px]">
      <p class="text-xs font-black uppercase tracking-[0.3em] text-brand-secondary">Memoria anual</p>
      <h1 class="mt-3 text-4xl font-black leading-tight md:text-5xl">Memoria Anual 2024</h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-brand-white/70 md:text-lg">
        Esta memoria reune nuestra gestion, acciones y principales hitos desarrollados durante el año 2024.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={previewPdfUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-brand-accent px-5 py-3 text-xs font-black uppercase tracking-[0.2em] text-brand-bg shadow-[0_12px_40px_rgba(254,209,0,0.28)] transition-transform duration-300 hover:-translate-y-[2px]"
        >
          Abrir vista web
        </a>
        <a
          href={originalPdfUrl}
          download
          class="inline-flex items-center gap-2 rounded-full border border-brand-white/15 px-5 py-3 text-xs font-black uppercase tracking-[0.2em] text-brand-white transition-colors hover:border-brand-accent/70 hover:text-brand-accent"
        >
          Descargar original
        </a>
      </div>
    </div>
  </section>

  <section class="bg-brand-white/5 py-10 text-brand-white lg:py-12">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-10 xl:max-w-[1440px]">
      <div class="overflow-hidden rounded-[32px] border border-brand-white/10 bg-brand-bg/70 shadow-[0_20px_70px_rgba(0,0,0,0.28)]">
        <iframe
          src={previewPdfUrl}
          title="Memoria Anual 2024"
          class="h-[78vh] min-h-[720px] w-full bg-white"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
