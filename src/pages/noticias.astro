---
import { getCollection } from 'astro:content';
import SidebarNav from '../components/SidebarNav.astro';
import Layout from '../layouts/Layout.astro';

const toSlug = (entry) => entry.slug ?? entry.id?.split('/').pop()?.replace(/\.(md|mdx)$/i, '') ?? '';

const posts = (await getCollection('posts'))
  .map((entry) => ({ ...entry, _slug: toSlug(entry) }))
  .filter((item) => typeof item._slug === 'string' && item._slug.length > 0)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const featuredPost = posts[0];
const remainingPosts = posts.slice(1);
---

<Layout title="Noticias">
  <SidebarNav />

  <section class="bg-brand-bg pb-14 pt-20 text-brand-white lg:pb-16 lg:pt-24">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-10 xl:max-w-[1440px]">
      <p class="text-xs font-black uppercase tracking-[0.3em] text-brand-secondary">Noticias</p>
      <h1 class="mt-3 text-4xl font-black leading-tight md:text-5xl">Historias y agenda de Arte y Vida.</h1>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-brand-white/70 md:text-lg">
        Actividades, hitos y programación cultural de nuestros proyectos en Ñuble.
      </p>
    </div>
  </section>

  <section class="bg-brand-white/5 py-16 text-brand-white lg:py-20">
    {featuredPost && (
      <div class="mx-auto mb-10 max-w-[1280px] px-6 sm:px-10 xl:max-w-[1440px]">
        <a
          href={`/posts/${featuredPost._slug}`}
          class="group grid overflow-hidden rounded-[36px] border border-brand-white/10 bg-brand-bg/70 shadow-[0_20px_80px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-1 hover:border-brand-accent/60 lg:grid-cols-12"
        >
          <div class="relative min-h-[260px] lg:col-span-7 lg:min-h-[420px]">
            <img
              src={featuredPost.data.coverImage ?? '/DSC06842-scaled.webp'}
              alt={featuredPost.data.title}
              class="h-full w-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
            <div class="absolute left-6 top-6">
              <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-black/30 px-4 py-2 text-[11px] font-black uppercase tracking-[0.2em] text-brand-white backdrop-blur">
                Noticia destacada
              </span>
            </div>
          </div>

          <div class="flex flex-col justify-between gap-6 px-6 py-7 lg:col-span-5 lg:px-8 lg:py-9">
            <div class="space-y-4">
              <div class="flex flex-wrap items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-brand-white/60">
                <span>
                  {new Date(featuredPost.data.date).toLocaleDateString('es-CL', {
                    day: '2-digit',
                    month: 'long',
                    year: 'numeric',
                  })}
                </span>
                <span class="inline-flex items-center gap-2 text-brand-accent">
                  <span class="h-1.5 w-1.5 rounded-full bg-brand-accent"></span>
                  Arte y Vida
                </span>
              </div>

              <h2 class="text-3xl font-black leading-tight group-hover:text-brand-accent md:text-4xl">
                {featuredPost.data.title}
              </h2>

              <div class="flex flex-wrap gap-2 text-[11px] uppercase tracking-[0.18em] text-brand-white/60">
                {(Array.isArray(featuredPost.data.categories) ? featuredPost.data.categories : [])
                  .filter((cat) => cat && cat.toLowerCase() !== 'sin-categoria')
                  .map((cat) => (
                    <span class="rounded-full border border-brand-white/10 bg-brand-white/5 px-3 py-1.5">{cat}</span>
                  ))}
              </div>

              <p class="max-w-xl text-sm leading-relaxed text-brand-white/72 md:text-base">
                Revisa la publicación más reciente de nuestra corporación y sigue los hitos, actividades y procesos que
                están marcando la agenda cultural del territorio.
              </p>
            </div>

            <div class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-brand-accent">
              Leer noticia
              <span class="inline-block h-2.5 w-2.5 rotate-45 border-r border-t border-current"></span>
            </div>
          </div>
        </a>
      </div>
    )}

    <div class="mx-auto grid max-w-[1280px] grid-cols-1 gap-6 px-6 sm:px-10 md:grid-cols-2 lg:grid-cols-3 xl:max-w-[1440px]">
      {remainingPosts.map((post, index) => {
        const rawCats = Array.isArray(post.data.categories) ? post.data.categories : [];
        const cleanCats = rawCats.filter((cat) => cat && cat.toLowerCase() !== 'sin-categoria');
        const categoriesToShow = cleanCats.length ? cleanCats : ['agenda-cultural'];
        return (
          <a
            href={`/posts/${post._slug}`}
            class="reveal-card overflow-hidden rounded-3xl border border-brand-white/10 bg-brand-bg/70 transition-all duration-300 hover:-translate-y-0.5 hover:border-brand-accent/60"
            style={`animation-delay: ${index * 60}ms;`}
          >
            <div class="h-40 w-full bg-cover bg-center" style={`background-image: url('${post.data.coverImage ?? '/DSC06842-scaled.webp'}')`}></div>
            <div class="flex flex-col gap-3 px-6 py-5">
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="text-lg font-bold leading-tight">{post.data.title}</h2>
                <span class="text-[11px] uppercase tracking-[0.18em] text-brand-white/60">
                  {new Date(post.data.date).toLocaleDateString('es-CL', { day: '2-digit', month: 'short', year: 'numeric' })}
                </span>
              </div>
              <div class="flex flex-wrap gap-2 text-[11px] uppercase tracking-[0.18em] text-brand-white/60">
                {categoriesToShow.map((cat) => (
                  <span class="rounded-full border border-brand-white/10 bg-brand-white/5 px-2 py-1">{cat}</span>
                ))}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
