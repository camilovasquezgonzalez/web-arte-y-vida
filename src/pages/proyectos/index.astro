---
import SidebarNav from '../../components/SidebarNav.astro';
import { getArchiveYears } from '../../lib/projectArchive';
import Layout from '../../layouts/Layout.astro';

const years = getArchiveYears();
---

<Layout title="Proyectos">
  <SidebarNav />

  <section class="bg-brand-bg pb-14 pt-20 text-brand-white lg:pb-16 lg:pt-24">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-10 xl:max-w-[1440px]">
      <p class="text-xs font-black uppercase tracking-[0.3em] text-brand-secondary">Proyectos</p>
      <h1 class="mt-3 max-w-5xl text-4xl font-black leading-tight md:text-5xl">
        Archivo visual de proyectos, procesos y acciones desarrolladas por ano.
      </h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-brand-white/70 md:text-lg">
        Recorre el trabajo de Arte y Vida a traves de proyectos organizados por ano, con registro fotografico completo
        y acceso directo a cada experiencia.
      </p>
    </div>
  </section>

  <section class="bg-brand-white/5 py-16 text-brand-white lg:py-20">
    <div class="mx-auto grid max-w-[1280px] grid-cols-1 gap-6 px-6 sm:px-10 lg:grid-cols-2 xl:max-w-[1440px]">
      {years.map((year, index) => (
        <a
          href={`/proyectos/${year.slug}`}
          class="group overflow-hidden rounded-[32px] border border-brand-white/10 bg-brand-bg/70 shadow-[0_20px_70px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-1 hover:border-brand-accent/60"
          style={`animation-delay: ${index * 90}ms;`}
        >
          <div class="relative h-64 overflow-hidden">
            <img
              src={year.coverImage}
              alt={`Portada ${year.title}`}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/25 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-4 px-6 py-6">
              <div>
                <p class="text-xs font-black uppercase tracking-[0.22em] text-brand-accent">Archivo anual</p>
                <h2 class="mt-2 text-4xl font-black leading-none text-brand-white md:text-5xl">{year.year}</h2>
              </div>
              <div class="rounded-full border border-brand-white/15 bg-black/30 px-4 py-2 text-[11px] uppercase tracking-[0.18em] text-brand-white/80">
                {year.projectCount} proyectos
              </div>
            </div>
          </div>

          <div class="space-y-4 px-6 py-6">
            <p class="text-sm leading-relaxed text-brand-white/75">{year.description}</p>

            <div class="flex flex-wrap gap-2 text-[11px] uppercase tracking-[0.18em] text-brand-white/60">
              {year.highlights.map((item) => (
                <span class="rounded-full border border-brand-white/10 bg-brand-white/5 px-2 py-1">{item}</span>
              ))}
            </div>

            <div class="flex items-center justify-between gap-4 pt-2 text-sm text-brand-white/70">
              <span>{year.photoCount.toLocaleString('es-CL')} imagenes</span>
              <span class="inline-flex items-center gap-2 font-semibold uppercase tracking-[0.14em] text-brand-accent group-hover:text-brand-white">
                Ver proyectos
                <span class="inline-block h-2.5 w-2.5 rotate-45 border-r border-t border-current"></span>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
